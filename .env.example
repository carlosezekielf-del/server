PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/namiskii
JWT_SECRET=replace_with_a_long_random_secret

# Web or domain origins (comma separated if multiple)
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000,https://your-domain.com
MOBILE_APP_URL=exp://127.0.0.1:19000

# Google sign-in
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMTP for forgot-password OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Namiskii Support <youremail@gmail.com>

# Optional: admin bootstrap (used by `npm run create-admin`)
ADMIN_NAME=Admin Namishkii
ADMIN_EMAIL=admin@namiskii.com
ADMIN_PASSWORD=admin123
