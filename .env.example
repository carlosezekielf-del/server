PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/namiskii
JWT_SECRET=replace_with_a_long_random_secret

# Web or domain origins (comma separated if multiple)
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000,https://your-domain.com
MOBILE_APP_URL=exp://127.0.0.1:19000

# Google sign-in
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
GOOGLE_EXPO_CLIENT_ID=your_expo_client_id.apps.googleusercontent.com

# Email for forgot-password OTP
# Option 1: Gmail SMTP on Vercel
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=yourgmail@gmail.com
SMTP_FROM_NAME=Namiskii Support

# Option 2: Resend (requires your own verified domain)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Namiskii Support <noreply@send.yourdomain.com>
RESEND_FROM_NAME=Namiskii Support
RESEND_FROM_EMAIL=noreply@send.yourdomain.com
EMAIL_TIMEOUT_MS=10000
