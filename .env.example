PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/namiskii
JWT_SECRET=replace_with_a_long_random_secret

# Web or domain origins (comma separated if multiple)
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000,https://your-domain.com
MOBILE_APP_URL=exp://127.0.0.1:19000

# Google sign-in
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email API for forgot-password OTP (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM=youremail@yourdomain.com
SENDGRID_FROM_NAME=Namiskii Support
EMAIL_TIMEOUT_MS=10000

# Optional: admin bootstrap (used by `npm run create-admin`)
ADMIN_NAME=Admin Namishkii
ADMIN_EMAIL=admin@namiskii.com
ADMIN_PASSWORD=admin123
